{
  "name": "esxc4",
  "version": "1.0.0",
  "description": "ESXC4 — Your private business command centre",
  "main": "main.js",
  "author": "ESXC4",
  "private": true,

  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "build-mac": "electron-builder --mac",
    "build-linux": "electron-builder --linux"
  },

  "build": {
    "appId": "com.xc4.app",
    "productName": "ESXC4",
    "copyright": "Private",

    "directories": {
      "output": "dist"
    },

    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "assets/**/*"
    ],

    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },

    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ESXC4"
    },

    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns",
      "category": "public.app-category.productivity"
    },

    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png",
      "category": "Office"
    }
  },

  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
